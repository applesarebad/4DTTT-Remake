---
import Layout from "../layouts/base.astro";
import "../styles/global.css";
import Lobby from "../components/lobby.astro";
---

<Layout>
    <Lobby />
    <div id="game">
        <a
            id="back"
            class="bg-purple-300 text-purple-900 text-xl font-bold px-4 py-2 rounded-sm hover:bg-purple-400 fixed top-6 left-3 md:top-10 md:left-29"
            href="/">back</a
        >
    <div
        id="all"
        class="flex flex-col md:flex-row justify-center items-center min-h-screen"
    >
        <div
            id="titleside"
            class="mflex min-w-[15%] md:flex-col md:gap-4 self-stretch items-center p-10"
        >
        </div>
        <div
            id="board"
            class="min-w-[min(100vh,100vw)] max-w-[min(100vh,100vw)] aspect-square p-2 flex-shrink-0"
        >
        </div>
        <div
            id="infoside"
            class="gap-4 items-center flex flex-1 flex-col self-stretch justify-center"
        >
            <div id="header" class="hidden md:block text-4xl font-bold">
                title
            </div>
            <div class="h-[5%]"></div>
            <div class="flex md:flex-col items-center justify-center">
                <div class="items-center flex flex-col">
                    <img
                        id="turn"
                        class="max-w-[30%] md:max-w-[70%] aspect-square"
                    />
                    <p id="turnmsg" class="text-3xl font-bold"></p>
                </div>
                <div class="md:h-[10%]"></div>

                <div
                    class="flex flex-col md:flex-row items-center justify-center"
                >
                    <p id="yourturnmsg" class="text-3xl md:text-3xl font-bold">
                    </p>
                    <img id="yourturnimg" class="aspect-square max-w-[30%]" />
                </div>
            </div>

            <div class="h-[10%]"></div>
            <div
                id="reset"
                class="bg-purple-300 text-purple-900 text-xl font-bold px-4 py-2 rounded-sm hover:bg-purple-400"
            >
                reset
            </div>
            <div class="h-auto"></div>
        </div>
    </div>
    </div>
</Layout>

<style>
    @import url("https://fonts.googleapis.com/css2?family=Indie+Flower&display=swap");
    @import url("https://fonts.googleapis.com/css2?family=Schoolbell&display=swap");
    * {
        font-family: "Schoolbell", cursive;
        font-weight: bold;
    }
</style>
<script
    src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"
></script>

<script>
    // @ts-nocheck
    import * as game from "../scripts/game.js";
    import * as single from "../scripts/single.js";
    let n = parseInt(localStorage.getItem("n")) || 4;
    let d = parseInt(localStorage.getItem("d")) || 4;
    let cpu = parseInt(localStorage.getItem("cpu")) || 0;
    let wmult = n <= 3 || d <= 2 ? 2 : 1;

    const role = new URLSearchParams(window.location.search).get("role");
    let online;
    let yourturn = 1;
    // lobby show/hide
    document.getElementById("hostview").style.display =
        role === "host" ? "flex" : "none";
    document.getElementById("joinview").style.display =
        role === "join" ? "flex" : "none";
    if (role === "host" || role === "join") {
        document.getElementById("game").style.display = "none";
        document.getElementById("yourturnmsg").innerHTML = "You are";
        online = true;
        document.getElementById("reset").style.visibility = "hidden";
    } else {
        showGame();
    }

    const peerConfig = {
        config: {
            iceServers: [
                { urls: "stun:stun.relay.metered.ca:80" },
                {
                    urls: "turn:global.relay.metered.ca:80",
                    username: "e67d7df8c6881e2c941f6efa",
                    credential: "o8x78SfNmzKDX9ux",
                },
                {
                    urls: "turn:global.relay.metered.ca:80?transport=tcp",
                    username: "e67d7df8c6881e2c941f6efa",
                    credential: "o8x78SfNmzKDX9ux",
                },
                {
                    urls: "turn:global.relay.metered.ca:443",
                    username: "e67d7df8c6881e2c941f6efa",
                    credential: "o8x78SfNmzKDX9ux",
                },
                {
                    urls: "turns:global.relay.metered.ca:443?transport=tcp",
                    username: "e67d7df8c6881e2c941f6efa",
                    credential: "o8x78SfNmzKDX9ux",
                },
            ],
        },
    };

    let peer, conn, code;

    function showGame() {
        document.getElementById("game").style.display = "block";
        document.getElementById("lobby").style.display = "none";
        start();
    }

    if (role === "host") {
        code = Math.random().toString(36).slice(2, 7).toUpperCase();
        document.getElementById("code").innerHTML = code;
        document.getElementById("yourturnimg").src = "/X/6.png";
        yourturn = 1;
        peer = new Peer(code, peerConfig);
        peer.on("error", (err) => console.log("peer error:", err.type, err));
        peer.on("connection", (c) => {
            conn = c;
            conn.send({ type: "init", n, d });
            conn.on("open", () => {
                console.log("host conn open, sending init");
                conn.send({ type: "init", n, d });
                showGame();
            });
            conn.on("data", (data) => {
                if (data.type == "move") {
                    game.onClick(data.x, data.y, data.w, data.z, data.who);
                } else if (data.type == "reset") {
                    restart(false);
                }
            });
            conn.on("close", () => {
                dc();
            });
        });
    }

    function dc() {
        const overlay = document.createElement("div");
        overlay.className =
            "fixed inset-0 flex justify-center items-center bg-purple-100/80";
        overlay.innerHTML = `<div class="text-5xl font-bold text-purple-900">opponent disconnected</div>`;
        document.body.appendChild(overlay);
        setTimeout(() => (window.location.href = "/"), 1000);
    }
    window.copyCode = () => navigator.clipboard.writeText(code);

    window.joinGame = () => {
        const input = document.getElementById("codeinput").value.toUpperCase();
        document.getElementById("yourturnimg").src = "/O/6.png";
        if (input.length < 5) return;
        document.getElementById("jbtn").style.visibility = "hidden";
        document.getElementById("joinstatus").style.visibility = "visible";
        document.getElementById("joinstatus").textContent = "searching...";

        peer = new Peer(peerConfig);
        peer.on("open", () => {
            yourturn = 2;
            conn = peer.connect(input);
            const timeout = setTimeout(() => {
                document.getElementById("joinstatus").innerHTML =
                    "connection failed. check your code";
                peer.destroy();
                peer = null;
                document.getElementById("jbtn").style.visibility = "visible";
            }, 4000);

            conn.on("data", (data) => {
                console.log("dsoijhhjsdo");
                if (data.type === "init") {
                    n = data.n;
                    d = data.d;
                    wmult = n <= 3 || d <= 2 ? 2 : 1;
                    showGame();
                } else if (data.type == "move") {
                    game.onClick(data.x, data.y, data.w, data.z, data.who);
                } else if (data.type == "reset") {
                    restart(false);
                }
            });

            conn.on("open", () => {
                clearTimeout(timeout);
            });

            conn.on("close", () => {
                dc();
            });
        });
    };

    // game

    function start() {
        gtag("event", "start_game", {
            cpu,
            online,
            n,
            d
        });
        let board = document.getElementById("board");
        let boardcopy = board.cloneNode(true);
        board.replaceWith(boardcopy);
        board = boardcopy;
        if (board == null) board = document.createElement("div");
        board.replaceChildren();

        board.style.display = "grid";
        board.style.gridTemplateColumns = `repeat(${n}, 1fr)`;
        board.style.gap = window.innerWidth < 768 ? "5px" : "10px";

        for (let i = 0; i < n; i++) {
            for (let j = 0; j < n; j++) {
                let sub = document.createElement("div");
                sub.style.display = "grid";
                sub.style.gridTemplateColumns = `repeat(${n}, 1fr)`;
                sub.className = "aspect-square";
                sub.style.gap = `${2 * wmult}px`;
                
                for (let k = 0; k < n; k++) {
                    for (let l = 0; l < n; l++) {
                        let cell = document.createElement("div");
                        cell.className =
                            "cell bg-white aspect-square rounded-sm";
                        cell.dataset.pos = `${l},${k},${j},${i}`;
                        sub.appendChild(cell);

                        if (d == 3 && i != j) {
                            cell.style.display = "none";
                        } else if (d == 2 && (j != 0 || i != 0)) {
                            cell.style.display = "none";
                            sub.style.display = "none";
                            board.style.display = "block";
                        }
                    }
                }
                board.appendChild(sub);
            }
        }

        board.addEventListener("click", (event) => {
            if (
                event.target instanceof HTMLElement &&
                event.target.classList.contains("cell")
            ) {
                const pos = event.target.dataset.pos;
                if (pos) {
                    let [x, y, w, z] = pos.split(",").map(Number);
                    //if (conn) conn.send({ x, y, w, z });
                    game.onClick(x, y, w, z, true);
                }
            }
        });

        board.addEventListener("mouseover", (event) => {
            if (
                event.target instanceof HTMLElement &&
                event.target.classList.contains("cell")
            ) {
                const pos = event.target.dataset.pos;
                if (pos) {
                    const [x, y, w, z] = pos.split(",").map(Number);
                    game.onHover(x, y, w, z);
                }
            }
        });

        board.addEventListener("mouseleave", () => game.onUnhover());
        game.init(n, d);
        if (online) game.onlineinit(yourturn, (data) => conn?.send(data));
        game.singleInit(cpu, yourturn);

        if (cpu > 0 && !online) {
            if (yourturn == 2) {
                setTimeout(() => {
                    let [x2, y2, w2, z2] = single.getTop(1, 20000)[0];
                    game.onClick(x2, y2, w2, z2, false);
                }, 300);
            }
        }
    }

    const reset = document.getElementById("reset");
    function restart(you = true) {
        yourturn = 3 - yourturn;
        if (online) {
            document.getElementById("yourturnimg").src =
                yourturn == 1 ? "/X/6.png" : "/O/6.png";
            if (you) conn.send({ type: "reset" });
        }

        start();
    }
    if (reset)
        reset.addEventListener("click", () => {
            restart();
        });

    const header = document.getElementById("header");
    if (header)
        header.innerHTML = n + (" X " + n).repeat(d - 1) + " Tic Tac Toe";
</script>
