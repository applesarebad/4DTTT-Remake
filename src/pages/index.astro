---
import Layout from "../layouts/base.astro";
import "../styles/global.css";
import titleimg from "../assets/Title.png";
---

<Layout>
	<div class="flex justify-center items-center gap-2 p-10 flex-col">
		<img src={titleimg.src} class="max-h-48 w-auto" />

		<div class="flex items-center justify-center gap-20">
		
			<!--size-->
			<div class="flex flex-col justify-center items-center">
				<div class="text-2xl text-purple-900">size</div>
				<div id="changen" class="flex gap-2 pt-2">
					<div class="btn" onclick="changen(2)">2</div>
					<div class="btn" onclick="changen(3)">3</div>
					<div class="btn" onclick="changen(4)">4</div>
					<div class="btn" onclick="changen(5)">5</div>
					<div class="btn" onclick="changen(6)">6</div>
				</div>
			</div>
			<!--dimension-->
			<div class="flex flex-col justify-center items-center">
				<div class="text-2xl text-purple-900">dimension</div>
				<div id="changed" class="flex gap-2 pt-2">
					<div class="btn" onclick="changed(2)">2</div>
					<div class="btn" onclick="changed(3)">3</div>
					<div class="btn" onclick="changed(4)">4</div>
				</div>
			</div>
		</div>
		<div id="warning" class="text-xl font-bold text-purple-900 pt-5">
			4x4x4x4 is recommended for new players. 5x5x5x5 is recommended for
			longer games.
		</div>
		<div class="flex justify-center w-[70%] pt-10">
			<!--single-->
			<div class="flex flex-col gap-4 w-1/2 justify-center items-center">
				<div class="text-2xl font-bold text-purple-900 pb-1">
					Singleplayer
				</div>
				<div class="flex flex-col justify-center w-1/2 gap-5">
					<button class="btn" onclick="startGame('/game', 1)"
						>easy</button
					>
					<button class="btn" onclick="startGame('/game', 2)"
						>medium</button
					>
					<button class="btn" onclick="startGame('/game', 3)"
						>hard</button
					>
				</div>
			</div>
			<!--mult-->
			<div class="flex flex-col gap-4 w-1/2 justify-center items-center">
				<div class="text-2xl font-bold text-purple-900 pb-1">
					Multiplayer
				</div>
				<div class="flex flex-col justify-center w-1/2 gap-5">
					<button class="btn" onclick="startGame('/game', 0)"
						>local</button
					>
					<button class="btn" onclick="startGame('/game?role=host', 0)"
						>host</button
					>
					<button class="btn" onclick="startGame('/game?role=join', 0)"
						>join</button
					>
				</div>
			</div>
		</div>
	</div>
</Layout>

<style>
	@reference "tailwindcss";
	.btn {
		@apply bg-purple-300 text-purple-900 text-xl font-bold px-4 py-2 rounded-sm hover:bg-purple-400 block text-center;
	}
	.btn.active {
		@apply bg-purple-600 text-white;
	}

	body {
		background: #ffaaaa;
		background: linear-gradient(
			90deg,
			rgba(255, 170, 170, 1) 0%,
			rgba(255, 221, 221, 1) 45%,
			rgba(221, 221, 255, 1) 55%,
			rgba(170, 170, 255, 1) 100%
		);
	}
</style>

<script is:inline>
	// @ts-nocheck

	on = localStorage.getItem("indicator") === "true";
	n = parseInt(localStorage.getItem("n")) || 4;
	d = parseInt(localStorage.getItem("d")) || 4;

	function setActive(group, value) {
		let el;
		switch (group) {
			case "size":
				el = document.getElementById("changen");
				break;
			case "dim":
				el = document.getElementById("changed");
				break;
			case "indicator":
				el = document.getElementById("changeIndicator");
				break;
		}
		for (const b of el.children) {
			b.classList.toggle(
				"active",
				b.textContent.trim() === String(value),
			);
		}
	}

	function changen(x) {
		localStorage.setItem("n", x);
		n = x;
		setActive("size", x);
		warningcheck();
	}
	function changed(x) {
		localStorage.setItem("d", x);
		d = x;
		setActive("dim", x);
		warningcheck();
	}

	function startGame(link, dif) {
		localStorage.setItem("cpu", dif);
		window.location.href = link;
	}

	setActive("size", n);
	setActive("dim", d);
	setActive("indicator", on ? "On" : "Off");
	warningcheck();

	function warningcheck() {
		el = document.getElementById("warning");
		if (n == 2) el.innerHTML = "Hmm...";
		else if (n == 3 && d >= 3)
			el.innerHTML =
				"A size of 3 in higher dimensions leads to an easy forced win. Try and find it!";
		else if (n - d >= 2 && d != 4)
			el.innerHTML =
				"When the size is much larger than the dimension, drawing is more common!";
		else if (n == 3 && d == 2) el.innerHTML = "Is this necessary...";
		else
			el.innerHTML =
				"4x4x4x4 is recommended for new players.   5x5x5x5 is recommended for longer games.";
	}
</script>
